//Write a program to input age of person and display.

age = int(input("Enter your age: "))

if age < 12:
    print("You are Kid")
elif 12 <= age <= 17:
    print("You are teenager")
elif 18 <= age <= 60:
    print("you are Adult")
elif age > 60:
    print("You are Senior Citizen")
else:
    print("Invalid age")

